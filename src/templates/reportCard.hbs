<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <title>{{studentName}} - Report Card</title>
  <style>
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #333;
      margin: 0;
      padding: 40px;
    }

    .header {
      text-align: center;
      border-bottom: 2px solid #2563EB;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }

    .header h1 {
      margin: 0;
      color: #1E3A8A;
      font-size: 28px;
    }

    .header p {
      margin: 5px 0 0;
      color: #64748B;
      font-size: 14px;
    }

    .student-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 30px;
      background: #F8FAFC;
      padding: 15px;
      border-radius: 8px;
    }

    .info-group {
      display: flex;
      flex-direction: column;
    }

    .info-label {
      font-size: 12px;
      color: #64748B;
      text-transform: uppercase;
      font-weight: bold;
    }

    .info-value {
      font-size: 16px;
      font-weight: 600;
      color: #0F172A;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
    }

    th {
      background: #EFF6FF;
      color: #1E3A8A;
      font-weight: 600;
      text-align: left;
      padding: 12px;
      border-bottom: 2px solid #BFDBFE;
    }

    td {
      padding: 12px;
      border-bottom: 1px solid #E2E8F0;
    }

    .score-cell {
      text-align: right;
      font-weight: 500;
    }

    .grade-A {
      color: #10B981;
      font-weight: bold;
    }

    .grade-B {
      color: #3B82F6;
      font-weight: bold;
    }

    .grade-C {
      color: #F59E0B;
      font-weight: bold;
    }

    .grade-D {
      color: #EA580C;
      font-weight: bold;
    }

    .grade-F {
      color: #EF4444;
      font-weight: bold;
    }

    .summary-box {
      border: 1px solid #E2E8F0;
      border-radius: 8px;
      padding: 20px;
      page-break-inside: avoid;
    }

    .summary-title {
      font-size: 18px;
      color: #1E3A8A;
      margin-top: 0;
      margin-bottom: 15px;
      border-bottom: 1px solid #E2E8F0;
      padding-bottom: 10px;
    }

    .footer {
      margin-top: 50px;
      text-align: center;
      font-size: 12px;
      color: #94A3B8;
      border-top: 1px solid #E2E8F0;
      padding-top: 20px;
    }
  </style>
</head>

<body>

  <div class="header">
    <h1>{{schoolName}}</h1>
    <p>Official {{examTitle}} Report Card - {{academicYear}}</p>
  </div>

  <div class="student-info">
    <div class="info-group">
      <span class="info-label">Student Name</span>
      <span class="info-value">{{studentName}}</span>
    </div>
    <div class="info-group">
      <span class="info-label">Enrollment ID</span>
      <span class="info-value">{{enrollmentNumber}}</span>
    </div>
    <div class="info-group">
      <span class="info-label">Class</span>
      <span class="info-value">{{className}}</span>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Subject</th>
        <th class="score-cell">Score</th>
        <th class="score-cell">Total</th>
        <th class="score-cell">%</th>
        <th>Grade</th>
        <th>Teacher Remarks</th>
      </tr>
    </thead>
    <tbody>
      {{#each subjectMarks}}
      <tr>
        <td>{{subjectName}}</td>
        <td class="score-cell">{{score}}</td>
        <td class="score-cell">{{totalPossible}}</td>
        <td class="score-cell">{{percentage}}%</td>
        <td class="grade-{{gradeBase}}">{{grade}}</td>
        <td style="font-size: 13px; color: #475569;">{{remarks}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="summary-box">
    <h3 class="summary-title">Performance Summary</h3>
    <div style="display: flex; justify-content: space-around; text-align: center; margin-bottom: 20px;">
      <div>
        <div class="info-label">Overall Percentage</div>
        <div class="info-value" style="font-size: 24px;">{{overallPercentage}}%</div>
      </div>
      <div>
        <div class="info-label">Overall Grade</div>
        <div class="info-value" style="font-size: 24px;">{{overallGrade}}</div>
      </div>
      <div>
        <div class="info-label">GPA</div>
        <div class="info-value" style="font-size: 24px;">{{gpa}}</div>
      </div>
      <div>
        <div class="info-label">Class Rank</div>
        <div class="info-value" style="font-size: 24px;">{{classRank}} / {{totalStudents}}</div>
      </div>
    </div>
    <div>
      <span class="info-label" style="display: block; margin-bottom: 5px;">Actionable Feedback</span>
      <p style="margin: 0; font-style: italic; color: #475569; font-size: 14px;">{{actionableFeedback}}</p>
    </div>
  </div>

  <div class="footer">
    Generated by Results Analysis App • This document is electronically generated and requires no physical signature.
  </div>

</body>

</html>